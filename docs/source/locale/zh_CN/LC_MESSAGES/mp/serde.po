#: ../../source/mp/serde.rst:56
msgid ""
"Quantize each element to 8-bit float; dequantize on load. Lossy but "
"highly compressible."
msgstr ""

#: ../../source/mp/serde.rst:58
msgid ""
"``fp8_dtype`` (default ``float8_e4m3fn``; also accepts ``float8_e5m2``), "
"``max_workers`` (thread pool size, default 1)"
msgstr ""

